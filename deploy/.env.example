# Copy this file to deploy/.env and fill in the values.
# This file is used by docker-compose.ec2.yml.

# Reddit API credentials (https://www.reddit.com/prefs/apps – "script" type app)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Google Gemini API key (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=

# EC2 public IP / hostname  (replace with your actual IP or domain)
FRONTEND_URL=http://YOUR_EC2_IP:3000
NEXT_PUBLIC_API_URL=http://YOUR_EC2_IP:8000
