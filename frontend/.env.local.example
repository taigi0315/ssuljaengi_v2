# ── Gossiptoon V2 Frontend – Local Environment ────────────────────────────────
# Copy this file to .env.local and fill in the values.
#
#   cp .env.local.example .env.local
#
# This file is NOT committed to git (.env.local is in .gitignore).
# ------------------------------------------------------------------------------

# URL of the Python FastAPI backend.
# For local development this is typically http://localhost:8000
# For EC2 production this is set automatically by the deploy workflow.
NEXT_PUBLIC_API_URL=http://localhost:8000
